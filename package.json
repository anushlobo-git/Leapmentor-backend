{
  "name": "optimal",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "build": "node -e \"console.log('No build step defined for backend')\"",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=18 <23",
    "npm": ">=9"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/setup.js"
    ],
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "services/**/*.js",
      "controllers/**/*.js",
      "repositories/**/*.js",
      "routes/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageReporters": [
      "text",
      "html",
      "lcov"
    ],
    "coverageDirectory": "coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@clerk/backend": "^3.0.1",
    "@logtail/node": "^0.5.8",
    "@logtail/winston": "^0.5.8",
    "@sentry/node": "^10.55.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "celebrate": "^15.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.5.0",
    "googleapi": "^1.0.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.9.4",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}